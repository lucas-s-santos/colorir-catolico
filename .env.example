# ==========================================================================
#  Ateliê Católico Digital — variáveis de ambiente
#  Copie este arquivo para `.env.local` e preencha com seus valores reais.
#  NUNCA versione o .env.local (ele já está no .gitignore).
# ==========================================================================

# --- URL pública do site (sem barra no final) ---------------------------
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase -----------------------------------------------------------
# Painel Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Service role key: SEGREDO. Só no servidor, nunca exposto ao cliente.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# --- Mercado Pago -------------------------------------------------------
# Painel Mercado Pago > Suas integrações > Credenciais
# Use as credenciais de TESTE para sandbox e as de PRODUÇÃO ao publicar.
MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxx-000000000
# Assinatura do webhook (Webhooks > configurar > "Chave secreta")
MERCADOPAGO_WEBHOOK_SECRET=sua-chave-secreta-do-webhook

# --- Resend (e-mail transacional) ---------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remetente verificado no Resend. Em testes pode usar onboarding@resend.dev
EMAIL_FROM=Ateliê Católico Digital <contato@seudominio.com.br>

# --- Regras de download -------------------------------------------------
DOWNLOAD_EXPIRES_DAYS=7          # validade do link de download (dias)
DOWNLOAD_MAX=5                   # nº máximo de downloads por compra
SIGNED_URL_TTL_SECONDS=600       # validade da URL assinada do PDF (segundos)

# --- Marca d'água (watermark) -------------------------------------------
# true = grava o e-mail do comprador no rodapé do PDF na entrega
WATERMARK_ENABLED=false
